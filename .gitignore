# ============================================
# Unity .gitignore
# ============================================

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ============================================
# Visual Studio / Rider / VS Code
# ============================================
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ============================================
# OS files
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# BMAD (personal, machine-local — never commit)
# ============================================
# Personal/user-scoped install answers and overrides; team config is committed.
**/*.user.toml
**/*.user.yaml
# Ignore generated output, but commit shared planning state (sprint status + story specs).
_bmad-output/
!_bmad-output/
_bmad-output/*
!_bmad-output/implementation-artifacts/

# ============================================
# Android Gradle templates generated by the Google External Dependency Manager
# (EDM4U, bundled with ARCore Extensions). The Plugins/Android/ folder is tracked
# (via .gitkeep) so EDM has a copy target, but the generated templates are not
# committed here — Android build config lands in the release-gate work (AR-21).
# ============================================
Assets/Plugins/Android/mainTemplate.gradle
Assets/Plugins/Android/mainTemplate.gradle.meta
Assets/Plugins/Android/gradleTemplate.properties
Assets/Plugins/Android/gradleTemplate.properties.meta
Assets/Plugins/Android/settingsTemplate.gradle
Assets/Plugins/Android/settingsTemplate.gradle.meta
Assets/Plugins/Android/launcherTemplate.gradle
Assets/Plugins/Android/launcherTemplate.gradle.meta
Assets/Plugins/Android/baseProjectTemplate.gradle
Assets/Plugins/Android/baseProjectTemplate.gradle.meta

# ============================================
# Secrets / keystores (NEVER commit)
# ============================================
*.keystore
*.jks
google-services.json
GoogleService-Info.plist
**/secrets/
*.env
keystore.properties
